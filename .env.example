# ==============================================================================
# AI INTELLIGENCE ZONE — Control Arena
# Environment Configuration Template
# ==============================================================================
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ==============================================================================

# ── Application ──────────────────────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://arena_user:arena_pass@localhost:5432/control_arena
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# ── Security ─────────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_SUBMIT=10/minute
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SESSION_LIFETIME_MINUTES=120
JWT_EXPIRY_HOURS=8
ADMIN_REGISTRATION_CODE=change-me-to-secret-admin-code

# ── Competition Settings ─────────────────────────────────────────────────────
COMPETITION_NAME=AI Intelligence Zone — Control Arena
MAX_TEAMS=50
MAX_TEAM_MEMBERS=4
SUBMISSION_COOLDOWN_SECONDS=10
MAX_RETRIES_PER_MISSION=20
COMPETITION_START=2026-03-15T09:00:00Z
COMPETITION_END=2026-03-15T18:00:00Z

# ── Scoring Weights ──────────────────────────────────────────────────────────
WEIGHT_ACCURACY=0.50
WEIGHT_SPEED=0.20
WEIGHT_VALIDATION=0.30
FIRST_BLOOD_BONUS=50
PERFECT_PARSE_BONUS=25
SPEED_DEMON_BONUS=30
CONSISTENCY_BONUS=20

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO

# ── Backup ───────────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=1
BACKUP_RETENTION_DAYS=30
